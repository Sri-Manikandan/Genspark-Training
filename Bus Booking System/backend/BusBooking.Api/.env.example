# ─────────────────────────────────────────────────────────────────
# DEPOT — .env template  (safe to commit — no real secrets here)
# cp .env.example .env  then fill in the blanks.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
ConnectionStrings__Default=Host=localhost;Port=5432;Database=bus_booking;Username=postgres;Password=YOUR_DB_PASSWORD;SSL Mode=Disable

# ── JWT ───────────────────────────────────────────────────────────
# Must be 32+ bytes.  Generate: openssl rand -base64 48
Jwt__SigningKey=REPLACE_WITH_32_PLUS_BYTE_RANDOM_STRING

# ── Razorpay ──────────────────────────────────────────────────────
# Dashboard → Settings → API Keys
Razorpay__KeyId=rzp_test_XXXXXXXXXXXX
Razorpay__KeySecret=YOUR_RAZORPAY_SECRET

# ── Resend (transactional email) ──────────────────────────────────
# https://resend.com/api-keys
Resend__ApiKey=re_XXXXXXXXXXXX

# ── Admin seed ────────────────────────────────────────────────────
AdminSeed__Email=admin@busbooking.local
AdminSeed__Password=ChangeMeOnFirstBoot!
